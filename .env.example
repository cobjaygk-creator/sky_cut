# Backend
APP_ENV=local
APP_NAME=New Cut
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./new_cut.db
JWT_SECRET_KEY=change-this-local-dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
MAX_UPLOAD_MB=500
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_HIGHLIGHT_MODEL=gpt-4o-mini
OPENAI_METADATA_MODEL=gpt-4o-mini
# TTS: openai (default) or typecast
TTS_PROVIDER=openai
TTS_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# Typecast (when TTS_PROVIDER=typecast). Free plan: 30k credits/month.
# TYPECAST_API_KEY falls back to TTS_API_KEY if empty.
TYPECAST_API_KEY=
TYPECAST_BASE_URL=https://api.typecast.ai
TYPECAST_MODEL=ssfm-v30
TYPECAST_VOICE_ID=
TYPECAST_LANGUAGE=kor
TRANSCRIPTION_CHUNK_MB=24
HIGHLIGHT_MIN_SECONDS=15
HIGHLIGHT_MAX_SECONDS=60
BLOG_IMAGE_MIN_COUNT=3
BLOG_IMAGE_MAX_COUNT=8
BLOG_FETCH_TIMEOUT_SECONDS=20
# Free Pexels API key for board stock search (Stage 20). Get one at https://www.pexels.com/api/
# Without this key, GET .../stock-search and POST .../stock-image return 400 with a clear message.
PEXELS_API_KEY=
STOCK_SEARCH_TIMEOUT_SECONDS=15
# Remotion R1: optional override for materialize target (default: ../remotion/public from backend)
REMOTION_PUBLIC_DIR=
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# R3: blog final render — remotion (default) or ffmpeg
BLOG_RENDER_ENGINE=remotion
REMOTION_SERVICE_URL=http://127.0.0.1:3100
REMOTION_SERVICE_TOKEN=
REMOTION_RENDER_TIMEOUT_SECONDS=600
BLOG_RENDER_FFMPEG_FALLBACK=true
# Phase-2 blog renders (TTS + Remotion/FFmpeg) concurrency; 1 = serial (recommended locally)
BLOG_RENDER_MAX_CONCURRENT=1

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# Future provider option
ELEVENLABS_API_KEY=
